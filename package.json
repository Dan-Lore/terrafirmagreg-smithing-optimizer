{
  "name": "terrafirmagreg-smithing-optimizer",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate-smithing": "tsx scripts/generate-smithing-data.ts",
    "generate-g-points-template": "tsx scripts/generate-g-points-template.ts",
    "build": "npm run generate-smithing && vite build",
    "preview": "vite preview",
    "precompute": "tsx scripts/precompute-paths.ts",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "eslint": "^9.21.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^15.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.25.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.2.0"
  }
}
